{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-06-28",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "ethcast",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"send_metrics": false,
	"workers_dev": true,
	"preview_urls": true
}
